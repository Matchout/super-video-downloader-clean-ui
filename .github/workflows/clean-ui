name: Clean UI Build v1

on:
  workflow_dispatch:
  push:
    paths:
      - ".github/workflows/clean-ui-build-v1.yml"
      - "app/**"
      - "build.gradle.kts"
      - "settings.gradle.kts"
      - "gradle.properties"
      - "gradle/**"
      - ".gitmodules"

jobs:
  build:
    runs-on: ubuntu-24.04

    steps:
      - name: Checkout source
        uses: actions/checkout@v4
        with:
          submodules: recursive

      - name: Set up JDK 21
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: "21"

      - name: Set up Android SDK
        uses: android-actions/setup-android@v3

      - name: Install Android SDK components
        run: |
          yes | sdkmanager --licenses
          sdkmanager "ndk;27.2.12479018" "cmake;3.22.1"

      - name: Set up Go
        uses: actions/setup-go@v5
        with:
          go-version: "1.25.7"

      - name: Set up Rust
        uses: dtolnay/rust-toolchain@stable

      - name: Grant execute permission for gradlew
        run: chmod +x ./gradlew

      - name: Apply Clean UI patch v1
        shell: bash
        run: |
          python3 <<'PY'
          from pathlib import Path
          import re

          root = Path("app/src/main/res")

          changed = []

          def edit_file(path, func):
              p = Path(path)
              if not p.exists():
                  print(f"SKIP missing: {path}")
                  return
              old = p.read_text(encoding="utf-8")
              new = func(old)
              if new != old:
                  p.write_text(new, encoding="utf-8")
                  changed.append(path)
                  print(f"PATCHED: {path}")
              else:
                  print(f"NOCHANGE: {path}")

          def replace_dp_values(text):
              # Conservative spacing reductions only.
              replacements = {
                  'android:paddingTop="96dp"': 'android:paddingTop="32dp"',
                  'android:paddingTop="88dp"': 'android:paddingTop="32dp"',
                  'android:paddingTop="80dp"': 'android:paddingTop="28dp"',
                  'android:layout_marginTop="96dp"': 'android:layout_marginTop="32dp"',
                  'android:layout_marginTop="88dp"': 'android:layout_marginTop="32dp"',
                  'android:layout_marginTop="80dp"': 'android:layout_marginTop="28dp"',
                  'android:layout_height="96dp"': 'android:layout_height="76dp"',
                  'android:layout_height="88dp"': 'android:layout_height="76dp"',
                  'app:itemIconSize="32dp"': 'app:itemIconSize="24dp"',
                  'app:itemIconSize="30dp"': 'app:itemIconSize="24dp"',
                  'app:itemIconSize="28dp"': 'app:itemIconSize="24dp"',
                  'app:cardCornerRadius="12dp"': 'app:cardCornerRadius="20dp"',
                  'app:cardCornerRadius="16dp"': 'app:cardCornerRadius="20dp"',
                  'app:cardElevation="2dp"': 'app:cardElevation="0dp"',
                  'app:cardElevation="4dp"': 'app:cardElevation="0dp"',
              }
              for a, b in replacements.items():
                  text = text.replace(a, b)
              return text

          # Patch likely layout files.
          layout_dir = root / "layout"
          if layout_dir.exists():
              for p in layout_dir.glob("*.xml"):
                  name = p.name.lower()
                  if any(k in name for k in [
                      "main", "browser", "settings", "navigation", "bottom", "progress", "video"
                  ]):
                      edit_file(p, replace_dp_values)

          # Patch menu icon size is usually controlled by BottomNavigationView attributes,
          # so no broad menu rewrite here.

          # Add soft divider color if colors.xml exists.
          colors = root / "values" / "colors.xml"
          def patch_colors(text):
              if "divider_soft" not in text:
                  text = text.replace("</resources>", "    <color name=\"divider_soft\">#1A000000</color>\n</resources>")
              return text
          edit_file(colors, patch_colors)

          print("Changed files:")
          for item in changed:
              print(" -", item)

          if not changed:
              raise SystemExit("Clean UI patch made no changes. File names or layout structure may differ.")
          PY

      - name: Build Debug APK
        run: |
          ./gradlew :app:assembleDebug --stacktrace --no-daemon

      - name: List APK outputs
        run: |
          find app/build/outputs/apk -type f -name "*.apk" -print

      - name: Upload Clean UI Debug APK
        uses: actions/upload-artifact@v4
        with:
          name: super-video-downloader-clean-ui-v1-debug-apk
          path: app/build/outputs/apk/debug/*.apk